  <structure>
    <volume name="absorber_log_0">
      <materialref ref="G4_Pb"/>
      <solidref ref="absorber_tube_0"/>
    </volume>
    <volume name="active_log_0">
      <materialref ref="G4_PLASTIC_SC_VINYLTOLUENE"/>
      <solidref ref="active_tube_0"/>
      <auxiliary auxtype="SensDet" auxvalue="CalorimeterSD"/>
    </volume>
    <volume name="absorber_log_1">
      <materialref ref="G4_Pb"/>
      <solidref ref="absorber_tube_1"/>
    </volume>
    <volume name="active_log_1">
      <materialref ref="G4_PLASTIC_SC_VINYLTOLUENE"/>
      <solidref ref="active_tube_1"/>
      <auxiliary auxtype="SensDet" auxvalue="CalorimeterSD"/>
    </volume>
    <volume name="absorber_log_2">
      <materialref ref="G4_Pb"/>
      <solidref ref="absorber_tube_2"/>
    </volume>
    <volume name="active_log_2">
      <materialref ref="G4_PLASTIC_SC_VINYLTOLUENE"/>
      <solidref ref="active_tube_2"/>
      <auxiliary auxtype="SensDet" auxvalue="CalorimeterSD"/>
    </volume>
    <volume name="absorber_log_3">
      <materialref ref="G4_Pb"/>
      <solidref ref="absorber_tube_3"/>
