<?xml version="1.0" encoding="UTF-8"?>
<gdml xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="http://service-spi.web.cern.ch/service-spi/app/releases/GDML/schema/gdml.xsd">

  <define>
    <constant name="PI" value="1.0*pi"/>
    <constant name="TWOPI" value="2.0*pi"/>
    <position name="center" x="0" y="0" z="0" unit="mm"/>
  </define>

  <materials>
    <!-- Element definitions -->
    <element name="Hydrogen" formula="H" Z="1">
      <atom value="1.00794"/>
    </element>
    <element name="Carbon" formula="C" Z="6">
      <atom value="12.0107"/>
    </element>
    <element name="Nitrogen" formula="N" Z="7">
      <atom value="14.0067"/>
    </element>
    <element name="Oxygen" formula="O" Z="8">
      <atom value="15.9994"/>
    </element>
    <element name="Iron_el" formula="Fe" Z="26">
      <atom value="55.845"/>
    </element>
    <element name="Chromium" formula="Cr" Z="24">
      <atom value="51.9961"/>
    </element>
    <element name="Nickel" formula="Ni" Z="28">
      <atom value="58.6934"/>
    </element>
    <element name="Lead_el" formula="Pb" Z="82">
      <atom value="207.2"/>
    </element>
    <element name="Tungsten_el" formula="W" Z="74">
      <atom value="183.84"/>
    </element>

    <!-- Air -->
    <material name="G4_AIR" formula="Air">
      <D value="0.00120479" unit="g/cm3"/>
      <fraction n="0.7" ref="Nitrogen"/>
      <fraction n="0.3" ref="Oxygen"/>
    </material>

    <!-- Stainless Steel (typical 304) -->
    <material name="G4_STAINLESS-STEEL" formula="Steel">
      <D value="7.93" unit="g/cm3"/>
      <fraction n="0.70" ref="Iron_el"/>
      <fraction n="0.19" ref="Chromium"/>
      <fraction n="0.10" ref="Nickel"/>
      <fraction n="0.01" ref="Carbon"/>
    </material>

    <!-- Iron -->
    <material name="G4_Fe" formula="Fe">
      <D value="7.874" unit="g/cm3"/>
      <fraction n="1.0" ref="Iron_el"/>
    </material>

    <!-- Aluminum -->
    <element name="Aluminum_el" formula="Al" Z="13">
      <atom value="26.982"/>
    </element>
    <material name="G4_Al" formula="Al">
      <D value="2.699" unit="g/cm3"/>
      <fraction n="1.0" ref="Aluminum_el"/>
    </material>

    <!-- Lead -->
    <material name="G4_Pb" formula="Pb">
      <D value="11.35" unit="g/cm3"/>
      <fraction n="1.0" ref="Lead_el"/>
    </material>

    <!-- Tungsten -->
    <material name="G4_W" formula="W">
      <D value="19.3" unit="g/cm3"/>
      <fraction n="1.0" ref="Tungsten_el"/>
    </material>

    <!-- Copper -->
    <element name="Copper_el" formula="Cu" Z="29">
      <atom value="63.546"/>
    </element>
    <material name="G4_Cu" formula="Cu">
      <D value="8.96" unit="g/cm3"/>
      <fraction n="1.0" ref="Copper_el"/>
    </material>

    <!-- Brass (70/30 Cu/Zn) -->
    <element name="Zinc_el" formula="Zn" Z="30">
      <atom value="65.38"/>
    </element>
    <material name="G4_BRASS" formula="CuZn">
      <D value="8.52" unit="g/cm3"/>
      <fraction n="0.70" ref="Copper_el"/>
      <fraction n="0.30" ref="Zinc_el"/>
    </material>

    <!-- Plastic Scintillator (polyvinyltoluene based) -->
    <material name="G4_PLASTIC_SC_VINYLTOLUENE" formula="C9H10">
      <D value="1.032" unit="g/cm3"/>
      <fraction n="0.915" ref="Carbon"/>
      <fraction n="0.085" ref="Hydrogen"/>
    </material>

    <!-- Polystyrene -->
    <material name="G4_POLYSTYRENE" formula="C8H8">
      <D value="1.06" unit="g/cm3"/>
      <fraction n="0.923" ref="Carbon"/>
      <fraction n="0.077" ref="Hydrogen"/>
    </material>

    <!-- Silicon -->
    <element name="Silicon_el" formula="Si" Z="14">
      <atom value="28.0855"/>
    </element>
    <material name="G4_Si" formula="Si">
      <D value="2.33" unit="g/cm3"/>
      <fraction n="1.0" ref="Silicon_el"/>
    </material>

    <!-- Copper -->
    <element name="Copper_el" formula="Cu" Z="29">
      <atom value="63.546"/>
    </element>
    <material name="G4_Cu" formula="Cu">
      <D value="8.96" unit="g/cm3"/>
      <fraction n="1.0" ref="Copper_el"/>
    </material>

    <!-- Brass (Cu 70%, Zn 30%) -->
    <element name="Zinc" formula="Zn" Z="30">
      <atom value="65.38"/>
    </element>
    <material name="G4_BRASS" formula="CuZn">
      <D value="8.52" unit="g/cm3"/>
      <fraction n="0.70" ref="Copper_el"/>
      <fraction n="0.30" ref="Zinc"/>
    </material>

    <!-- Liquid Argon -->
    <element name="Argon_el" formula="Ar" Z="18">
      <atom value="39.948"/>
    </element>
    <material name="G4_lAr" formula="Ar">
      <D value="1.396" unit="g/cm3"/>
      <fraction n="1.0" ref="Argon_el"/>
    </material>

    <!-- Crystal calorimeter materials -->
    <element name="Cesium" formula="Cs" Z="55">
      <atom value="132.905"/>
    </element>
    <element name="Iodine" formula="I" Z="53">
      <atom value="126.904"/>
    </element>
    <material name="G4_CESIUM_IODIDE" formula="CsI">
      <D value="4.51" unit="g/cm3"/>
      <fraction n="0.512" ref="Cesium"/>
      <fraction n="0.488" ref="Iodine"/>
    </material>

    <element name="Bismuth" formula="Bi" Z="83">
      <atom value="208.98"/>
    </element>
    <element name="Germanium" formula="Ge" Z="32">
      <atom value="72.63"/>
    </element>
    <material name="G4_BGO" formula="Bi4Ge3O12">
      <D value="7.13" unit="g/cm3"/>
      <fraction n="0.671" ref="Bismuth"/>
      <fraction n="0.175" ref="Germanium"/>
      <fraction n="0.154" ref="Oxygen"/>
    </material>

    <material name="G4_PbWO4" formula="PbWO4">
      <D value="8.28" unit="g/cm3"/>
      <fraction n="0.455" ref="Lead_el"/>
      <fraction n="0.404" ref="Tungsten_el"/>
      <fraction n="0.141" ref="Oxygen"/>
    </material>

    <element name="Lutetium" formula="Lu" Z="71">
      <atom value="174.967"/>
    </element>
    <element name="Yttrium_el" formula="Y" Z="39">
      <atom value="88.906"/>
    </element>
    <material name="G4_LYSO" formula="Lu2SiO5">
      <D value="7.4" unit="g/cm3"/>
      <fraction n="0.714" ref="Lutetium"/>
      <fraction n="0.040" ref="Yttrium_el"/>
      <fraction n="0.064" ref="Silicon_el"/>
      <fraction n="0.182" ref="Oxygen"/>
    </material>

  </materials>

  <solids>
    <box name="world_solid" x="50000.0" y="50000.0" z="50000.0" lunit="mm"/>
    <tube name="absorber_tube_0" rmin="50.0" rmax="51.5" z="300.0" deltaphi="TWOPI" aunit="rad" lunit="mm"/>
